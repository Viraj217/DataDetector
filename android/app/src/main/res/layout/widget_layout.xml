<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Value text layout -->
    <LinearLayout
        android:id="@+id/value_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:baselineAligned="true">

        <TextView
            android:id="@+id/widget_usage_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#F8F8FF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_usage_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" GB"
            android:textColor="#FF007F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginLeft="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consumed Today"
        android:textColor="#A5A6F6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_below="@id/value_layout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="2dp" />

    <!-- Progress bar & text -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_drawable"
        android:layout_below="@id/widget_label"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="8dp" />

    <TextView
        android:id="@+id/widget_progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0% of budget"
        android:textColor="#666999"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_below="@id/widget_progress"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="6dp" />

</RelativeLayout>
